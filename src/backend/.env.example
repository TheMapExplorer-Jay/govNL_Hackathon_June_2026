# ──────────────────────────────────────────────────────────────────────────────
# LLM
# ──────────────────────────────────────────────────────────────────────────────
# The LLM helper (src/backend/app/services/llm.py) is wired to GreenPT:
# the base URL is hardcoded to https://api.greenpt.ai/v1 and the API key
# is read from GREENPT_KEY. GreenPT credentials are offered to OneGov #2
# hackathon teams by Provincie Zuid-Holland; see docs.greenpt.ai.
GREENPT_KEY=""
OPENAI_MODEL="gemma4"

# ──────────────────────────────────────────────────────────────────────────────
# Server
# ──────────────────────────────────────────────────────────────────────────────
PORT=8000
DEBUG=false
# Second assignment wins; "*" is convenient for local dev.
ALLOWED_ORIGINS="http://localhost:5173"
ALLOWED_ORIGINS="*"

# ──────────────────────────────────────────────────────────────────────────────
# Database
# ──────────────────────────────────────────────────────────────────────────────
DATABASE_URL="postgresql+asyncpg://ruimtelijke:secret123!@localhost:5432/sessions"
